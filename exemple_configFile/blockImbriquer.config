server {
	listen 8080;
	root ./www;
	client_max_body_size 10M;

	location / {
		allow_methods GET;
		autoindex on;
	}

	location /cgi-bin {
		root ./scripts;
		allow_methods GET POST;
		cgi_ext .py;
		cgi_path /usr/bin/python3;
	}

	location /upload {
		allow_methods POST DELETE;
		upload_store ./www/uploads;
	}
}